# ═══════════════════════════════════════════════════════════════════════════════
# .env.local.example — Local development environment
#
# Copy to .env.local (never commit .env.local):
#   cp .env.local.example .env.local
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
API_URL=http://localhost:3000

# ── Supabase (Auth + Users + Workspaces + File Metadata) ─────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Frontend (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Database (PostgreSQL — can be the same DB as Supabase) ───────────────────
DATABASE_URL=postgresql://loraloop:loraloop_secret@localhost:5432/loraloop_db

# ── Cloudflare R2 Storage ─────────────────────────────────────────────────────
# Account ID — found in Cloudflare dashboard → R2 → Overview
R2_ACCOUNT_ID=7e32b6acb4a280d3ab70b0d6ff02c455

# R2 API credentials — created in Cloudflare R2 → Manage API Tokens
R2_ACCESS_KEY_ID=ccea3e981477ea6cb0dd5599534e209e
R2_SECRET_ACCESS_KEY=ed5a1f430fb292764bf77e251c6fc6dad3efac0ad0ec575b3d16200e0420a54a

# Bucket name — create at https://dash.cloudflare.com/ → R2 → Create bucket
R2_BUCKET_NAME=laraloop-storage

# Explicit S3-compatible endpoint
R2_ENDPOINT=https://7e32b6acb4a280d3ab70b0d6ff02c455.r2.cloudflarestorage.com

# Optional: Custom public CDN URL (set a custom domain on the R2 bucket)
# R2_PUBLIC_URL=https://cdn.yourdomain.com

# ── Frontend API URLs ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-32-char-random-string-min-length-32
JWT_REFRESH_SECRET=replace-with-different-refresh-secret-min-32

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-64-hex-char-string-32-bytes

# ── AI (set at least one) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# ── Cache / Queues ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Vector DB ────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
